# Публичный URL сайта (без слэша в конце) — для robots.txt и sitemap.xml при сборке
VITE_SITE_URL=https://ses88.ru

# OAuth (вход в /admin/leads) — подставляются в клиент при vite build
# VITE_OAUTH_PORTAL_URL=https://...
# VITE_APP_ID=...

# Код подтверждения Яндекс.Вебмастер: Настройки → Индексирование → Файл HTML / meta-тег
# VITE_YANDEX_VERIFICATION=xxxxxxxxxxxxxxxx

# Umami (если используется)
# VITE_ANALYTICS_ENDPOINT=
# VITE_ANALYTICS_WEBSITE_ID=

# PostgreSQL (сервер)
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/sanservice

# amoCRM — без этих переменных заявки в CRM не уходят (сохраняются только в БД сайта)
# AMO_SUBDOMAIN=ваш_поддомен
# AMO_CLIENT_ID=
# AMO_CLIENT_SECRET=
# Redirect URI в настройках интеграции amoCRM должен совпадать с прод-доменом:
# AMO_REDIRECT_URI=https://ses88.ru/api/amocrm/oauth
# После деплоя: зайти в админку → привязать amoCRM (OAuth) или вручную:
# AMO_ACCESS_TOKEN=
# AMO_REFRESH_TOKEN=
